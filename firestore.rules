rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own data
    match /users/{userId}/data/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Feedback collection - any authenticated user can write
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read: if false;
    }
    // Office spaces – public read; owner-only write for offices & settings
    match /officeSpaces/{ownerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerId;
      match /offices/{officeId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == ownerId;
      }
      match /meta/{docId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == ownerId;
      }
      // Bookings: public can create (book); only owner can update/delete
      match /bookings/{bookingId} {
        allow read: if request.auth != null && request.auth.uid == ownerId;
        allow create: if true;
        allow update, delete: if request.auth != null && request.auth.uid == ownerId;
      }
    }
  }
}
